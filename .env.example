# Strava
STRAVA_CLUB_ID=40422
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
# Must be a read_all-scoped refresh token — read-only tokens cannot see the
# club's new-format events. (See scripts/capture-refresh-token.mjs.)
STRAVA_REFRESH_TOKEN=your_read_all_refresh_token

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...        # bound to #ride-calls-only
SLACK_WEBHOOK_URL_FTWNB=https://hooks.slack.com/services/...  # bound to #ftwnb (women-only rides)
# Optional test webhook (e.g. bound to a DM). When set, ALL messages redirect
# here instead of the real channels, tagged with the intended destination.
SLACK_WEBHOOK_URL_TEST=https://hooks.slack.com/services/...

# Testing only — bypass the noon-hour guard so dev/manual runs fire any time
SKIP_NOON_GUARD=
